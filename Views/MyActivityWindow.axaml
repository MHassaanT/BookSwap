<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:BookSwap.Core"
        x:Class="BookSwap.Views.MyActivityWindow"
        Title="My Activity" Width="700" Height="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15" RowDefinitions="Auto,*">
        <TextBlock Grid.Row="0" Text="My Activity Dashboard" FontSize="22" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>
        
        <TabControl Grid.Row="1">
            <!-- TAB 1: My Listings -->
            <TabItem Header="My Listings">
                <Grid RowDefinitions="Auto,*">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,10,0,10">
                        <TextBlock Text="Double-click a listing to edit it." FontStyle="Italic" Foreground="#666"/>
                    </StackPanel>
                    
                    <ListBox x:Name="lstMyListings" Grid.Row="1" DoubleTapped="OnListingDoubleTapped">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="core:Book">
                                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Margin="5" Padding="10">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16"/>
                                            <TextBlock Text="{Binding Category}" Foreground="#007ACC"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding DisplayPrice}" FontSize="16" Foreground="#28A745" FontWeight="Bold" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding Status}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>
            
            <!-- TAB 2: My Orders -->
            <TabItem Header="My Orders (Purchases)">
                <ListBox x:Name="lstMyOrders" Margin="0,10,0,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="core:Transaction">
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Margin="5" Padding="10">
                                <Grid ColumnDefinitions="*, Auto">
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding BookTitle}" FontWeight="Bold" FontSize="16"/>
                                        <TextBlock Text="{Binding Date, StringFormat={}{0:g}}" Foreground="#666"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding FinalPrice, StringFormat={}{0:C}}" FontSize="16" Foreground="#28A745" FontWeight="Bold" HorizontalAlignment="Right"/>
                                        <TextBlock Text="Bought from: " Foreground="#555" FontSize="12" HorizontalAlignment="Right"/>
                                        <TextBlock Text="{Binding SellerName}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
