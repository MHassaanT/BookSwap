<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BookSwap.Views.CheckoutWindow"
        Title="Checkout" Width="400" Height="350"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20" Spacing="15">
        <TextBlock Text="Checkout Preview" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
        
        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="15" Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" Margin="5">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Item:" FontWeight="Bold" Margin="0,0,15,5"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtItemName" TextWrapping="Wrap" Margin="0,0,0,5"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Seller:" FontWeight="Bold" Margin="0,0,15,5"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtSellerName" Margin="0,0,0,5"/>
                
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Total:" FontSize="18" FontWeight="Bold" Margin="0,15,15,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtTotal" FontSize="18" FontWeight="Bold" Foreground="#28A745" Margin="0,15,0,0"/>
            </Grid>
        </Border>
        
        <TextBlock Text="By confirming, you agree to buy this book." FontStyle="Italic" HorizontalAlignment="Center" Foreground="#666"/>
        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15" Margin="0,10,0,0">
            <Button Content="Cancel" Width="100" HorizontalContentAlignment="Center" Click="OnCancelClick"/>
            <Button Content="Confirm Purchase" Width="150" HorizontalContentAlignment="Center" Background="#007ACC" Foreground="White" Click="OnConfirmClick"/>
        </StackPanel>
    </StackPanel>
</Window>
