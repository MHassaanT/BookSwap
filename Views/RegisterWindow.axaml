<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BookSwap.Views.RegisterWindow"
        Title="BookSwap - Register" Width="450" Height="550"
        WindowStartupLocation="CenterScreen">
    <ScrollViewer>
        <StackPanel Margin="20" Spacing="10">
            <TextBlock Text="Register New Account" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            
            <TextBlock Text="Name" FontWeight="SemiBold"/>
            <TextBox x:Name="txtName" Watermark="e.g. John Doe"/>
            
            <TextBlock Text="Email" FontWeight="SemiBold"/>
            <TextBox x:Name="txtEmail" Watermark="e.g. john@example.com"/>
            
            <TextBlock Text="Password" FontWeight="SemiBold"/>
            <TextBox x:Name="txtPassword" Watermark="Choose a password" PasswordChar="*"/>
            
            <TextBlock Text="Contact Info" FontWeight="SemiBold"/>
            <TextBox x:Name="txtContact" Watermark="Phone or link"/>
            
            <TextBlock Text="Role" FontWeight="SemiBold"/>
            <ComboBox x:Name="cmbRole" SelectedIndex="0" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="Student"/>
                <ComboBoxItem Content="Admin"/>
            </ComboBox>
            
            <TextBlock x:Name="txtMessage" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            
            <Button Content="Register" HorizontalAlignment="Center" Background="#28A745" Foreground="White" Width="120" HorizontalContentAlignment="Center" Click="OnRegisterClick" Margin="0,10,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Window>
