<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:BookSwap.Core"
        x:Class="BookSwap.Views.ManageListingsWindow"
        Title="Manage Listings" Width="700" Height="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15" RowDefinitions="Auto,*,Auto">
        <TextBlock Grid.Row="0" Text="Manage All Listings" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
        
        <ListBox x:Name="lstListings" Grid.Row="1" Margin="0,10,0,10">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="core:Book">
                    <Border BorderBrush="#CCC" BorderThickness="1" CornerRadius="5" Padding="10" Margin="5">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="{Binding Seller, StringFormat='Seller: {0}'}" Foreground="#555"/>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="{Binding Status}" Foreground="#007ACC" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding DisplayPrice}" Foreground="#28A745" FontWeight="Bold"/>
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Delete" Background="#DC3545" Foreground="White" 
                                    VerticalAlignment="Center" Click="OnDeleteListingClick" Tag="{Binding ID}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <Button Grid.Row="2" Content="Close" Width="100" HorizontalContentAlignment="Center" HorizontalAlignment="Center" Click="OnCloseClick"/>
    </Grid>
</Window>
