<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BookSwap.Views.LoginWindow"
        Title="BookSwap - Login" Width="400" Height="300"
        WindowStartupLocation="CenterScreen"
        CanResize="False">
    <StackPanel Margin="20" Spacing="15" VerticalAlignment="Center">
        <TextBlock Text="Welcome to BookSwap" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
        
        <TextBlock Text="Email :" FontWeight="SemiBold"/>
        <TextBox x:Name="txtEmail" Watermark="Enter your email"/>
        
        <TextBlock Text="Password :" FontWeight="SemiBold"/>
        <TextBox x:Name="txtPassword" Watermark="Enter your password" PasswordChar="*"/>
        
        <TextBlock x:Name="txtError" Foreground="Red" HorizontalAlignment="Center" IsVisible="False"/>
        
        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Register" Width="100" HorizontalContentAlignment="Center" Click="OnRegisterClick"/>
            <Button Content="LOGIN" Width="100" HorizontalContentAlignment="Center" Background="#007ACC" Foreground="White" Click="OnLoginClick"/>
        </StackPanel>
    </StackPanel>
</Window>
