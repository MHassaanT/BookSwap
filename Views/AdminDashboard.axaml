<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BookSwap.Views.AdminDashboard"
        Title="Admin Dashboard" Width="600" Height="400"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20" Spacing="20">
        <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="Admin Dashboard" FontSize="26" FontWeight="Bold" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                <Button Content="Go to Catalog" Click="OnCatalogClick"/>
                <Button Content="Logout" Click="OnLogoutClick" Background="#DC3545" Foreground="White"/>
            </StackPanel>
        </Grid>

        <!-- Stats row -->
        <Grid ColumnDefinitions="*,*,*" Margin="0,15,0,0">
            <!-- Total Users -->
            <Border Grid.Column="0" Background="#17A2B8" CornerRadius="5" Padding="20" Margin="5">
                <StackPanel>
                    <TextBlock Text="Total Users" Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtTotalUsers" Text="0" Foreground="White" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Active Listings -->
            <Border Grid.Column="1" Background="#28A745" CornerRadius="5" Padding="20" Margin="5">
                <StackPanel>
                    <TextBlock Text="Active Listings" Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtActiveListings" Text="0" Foreground="White" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Total Sales -->
            <Border Grid.Column="2" Background="#FFC107" CornerRadius="5" Padding="20" Margin="5">
                <StackPanel>
                    <TextBlock Text="Total Sales" Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtTotalSales" Text="$0.00" Foreground="White" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20" Margin="0,30,0,0">
            <Button Content="Manage Users" FontSize="18" Padding="15,10" Click="OnManageUsersClick"/>
            <Button Content="Manage Listings" FontSize="18" Padding="15,10" Click="OnManageListingsClick"/>
        </StackPanel>
    </StackPanel>
</Window>
