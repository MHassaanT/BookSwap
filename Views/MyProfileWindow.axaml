<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BookSwap.Views.MyProfileWindow"
        Title="My Profile" Width="400" Height="400"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="My Profile" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
        
        <TextBlock Text="Role / ID" FontWeight="SemiBold" Margin="0,10,0,0"/>
        <TextBlock x:Name="txtRole" Foreground="Gray"/>
        
        <TextBlock Text="Email (Read-only)" FontWeight="SemiBold"/>
        <TextBox x:Name="txtEmail" IsReadOnly="True" Background="#F0F0F0"/>
        
        <TextBlock Text="Name" FontWeight="SemiBold"/>
        <TextBox x:Name="txtName"/>
        
        <TextBlock Text="Contact Info" FontWeight="SemiBold"/>
        <TextBox x:Name="txtContact"/>
        
        <TextBlock Text="Password" FontWeight="SemiBold"/>
        <TextBox x:Name="txtPassword" PasswordChar="*"/>
        
        <TextBlock x:Name="txtStatus" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0" Foreground="Green"/>
        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,10,0,0">
            <Button Content="Discard Changes" Click="OnDiscardClick"/>
            <Button Content="Save Profile" Background="#007ACC" Foreground="White" Click="OnSaveClick"/>
        </StackPanel>
    </StackPanel>
</Window>
