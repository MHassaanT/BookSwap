<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:BookSwap.Core"
        x:Class="BookSwap.Views.CatalogWindow"
        Title="BookSwap Catalog" Height="700" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15" RowDefinitions="Auto,*">
        <!-- Top Nav & Filter Bar -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,15">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Catalog" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0"/>
                
                <TextBox x:Name="txtSearch" Width="200" 
                         Watermark="Search Title or Author..." 
                         KeyUp="OnSearchKeyUp"/>
                
                <ComboBox x:Name="cmbCategory" Width="150" 
                          SelectedIndex="0"
                          SelectionChanged="OnCategoryChanged">
                    <ComboBoxItem Content="All Categories"/>
                    <ComboBoxItem Content="Engineering"/>
                    <ComboBoxItem Content="Science"/>
                    <ComboBoxItem Content="Arts"/>
                </ComboBox>

                <Slider x:Name="sldPrice" Width="100" Minimum="0" Maximum="200" 
                        Value="200" PropertyChanged="OnSliderChanged" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding #sldPrice.Value, StringFormat={}{0:C}}" 
                           VerticalAlignment="Center" FontWeight="SemiBold"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Button Content="Add Listing" Click="OnAddListingClick" Background="#28A745" Foreground="White"/>
                <Button Content="My Activity" Click="OnMyActivityClick"/>
                <Button Content="My Profile" Click="OnMyProfileClick"/>
                <Button Content="Logout" Click="OnLogoutClick" Background="#DC3545" Foreground="White"/>
            </StackPanel>
        </Grid>

        <!-- Catalog Grid -->
        <ListBox x:Name="lstBooks" Grid.Row="1" DoubleTapped="OnBookDoubleTapped">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="core:Book">
                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Margin="5" Padding="15" Background="White">
                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Author}" FontStyle="Italic" Foreground="#555"/>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="{Binding Category}" Foreground="#007ACC" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Condition}" Foreground="#666"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="5">
                                <TextBlock Text="{Binding DisplayPrice}" FontSize="18" Foreground="#28A745" FontWeight="Bold" HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding Status}" FontWeight="SemiBold" HorizontalAlignment="Right"
                                           Foreground="{Binding IsAvailable, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                           <!-- A simple converter or style could be better, but we will leave status coloring to code or ignore for now -->
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>